@habitId = 31355931-3d06-4319-b31d-b311fe3b0bba
@nutritionQuery = banana
@nutritionEntryId = REPLACE-WITH-NUTRITION-ENTRY-ID

### Health check
GET {{baseUrl}}/health

### Signup
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "email": "demo@example.com",
  "password": "password123",
  "name": "Demo User"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "demo@example.com",
  "password": "password123"
}

### Get current user
GET {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Delete current user
DELETE {{baseUrl}}/users/me
Authorization: Bearer {{token}}

### Create habit
POST {{baseUrl}}/habits
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Workout",
  "notes": "Upper body on Mondays"
}

### List habits
GET {{baseUrl}}/habits
Authorization: Bearer {{token}}

### Get habit
GET {{baseUrl}}/habits/{{habitId}}
Authorization: Bearer {{token}}

### Update habit
PATCH {{baseUrl}}/habits/{{habitId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Workout 5x/week",
  "notes": "Upper/lower split",
  "isActive": true
}

### Delete habit
DELETE {{baseUrl}}/habits/{{habitId}}
Authorization: Bearer {{token}}

### Create checkin with explicit date
POST {{baseUrl}}/habits/{{habitId}}/checkins
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "checkinDate": "2026-03-14"
}

### Create checkin for today
POST {{baseUrl}}/habits/{{habitId}}/checkins
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### List checkins
GET {{baseUrl}}/habits/{{habitId}}/checkins
Authorization: Bearer {{token}}

### Delete checkin by date
DELETE {{baseUrl}}/habits/{{habitId}}/checkins/2026-03-14
Authorization: Bearer {{token}}

### Nutrition search
GET {{baseUrl}}/nutrition/search?q={{nutritionQuery}}
Authorization: Bearer {{token}}

### Nutrition search again to hit cache
GET {{baseUrl}}/nutrition/search?q={{nutritionQuery}}
Authorization: Bearer {{token}}

### Nutrition search with branded food
GET {{baseUrl}}/nutrition/search?q=chobani%20greek%20yogurt
Authorization: Bearer {{token}}

### Nutrition search validation error
GET {{baseUrl}}/nutrition/search?q=a
Authorization: Bearer {{token}}

### Create nutrition entry
POST {{baseUrl}}/nutrition/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "foodName": "Banana, raw",
  "brandName": null,
  "fdcId": 173944,
  "consumedOn": "2026-04-15",
  "servings": 1.5,
  "caloriesPerServing": 89,
  "servingSize": 100,
  "servingSizeUnit": "g"
}

### Create nutrition entry from USDA per-100g result
POST {{baseUrl}}/nutrition/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "foodName": "Yogurt, Greek, whole, plain, CHOBANI",
  "brandName": null,
  "fdcId": 171309,
  "consumedOn": "2026-04-15",
  "servings": 1.50,
  "caloriesPerServing": 82,
  "servingSize": 100,
  "servingSizeUnit": "g"
}

### Create manual calorie entry
POST {{baseUrl}}/nutrition/entries
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "foodName": "Homemade smoothie",
  "brandName": null,
  "fdcId": null,
  "consumedOn": "2026-04-15",
  "servings": 1,
  "caloriesPerServing": 450,
  "servingSize": null,
  "servingSizeUnit": null
}

### List nutrition entries for a date
GET {{baseUrl}}/nutrition/entries?date=2026-04-15
Authorization: Bearer {{token}}

### Delete nutrition entry
DELETE {{baseUrl}}/nutrition/entries/{{nutritionEntryId}}
Authorization: Bearer {{token}}
